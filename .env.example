# ⚛️ SPIMAG Environment Variables
# Copy to .env and fill in your values

# Database
DB_PASSWORD=your_secure_password_here

# External APIs
NOAA_API_KEY=your_noaa_api_key_here
INTERMAGNET_TOKEN=your_intermagnet_token_here

# Security
JWT_SECRET=your_jwt_secret_key_here
SECRET_KEY=your_django_flask_secret_key_here

# Server
SPIMAG_HOST=0.0.0.0
SPIMAG_PORT=8000
SPIMAG_DASHBOARD_PORT=8501

# Logging
LOG_LEVEL=INFO

# Development
FLASK_ENV=development
DEBUG=true

# Production (uncomment in production)
# FLASK_ENV=production
# DEBUG=false
# SPIMAG_CONFIG=/etc/spimag/config.yaml

# ⚛️ Inside the eye of a migrating robin, two electrons are entangled.
